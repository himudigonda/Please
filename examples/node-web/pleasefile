version = "0.5"

test:
    @in package.json src/**/*.js
    @out .please/stamps/test.ok
    @isolation off
    mkdir -p .please/stamps
    npm test
    printf 'ok\n' > .please/stamps/test.ok

build: test
    @in package.json src/**/*.js scripts/build.mjs
    @out dist/src
    @isolation off
    npm run build

ci: build
    @in pleasefile
    @out .please/stamps/ci.ok
    @isolation off
    mkdir -p .please/stamps
    printf 'ok\n' > .please/stamps/ci.ok
