[please]
version = "0.1"

[task.gen]
inputs = ["data/input.txt"]
outputs = ["build/out.txt"]
run = "mkdir -p build && tr '[:lower:]' '[:upper:]' < data/input.txt > build/out.txt"

[task.package]
deps = ["gen"]
inputs = ["build/out.txt"]
outputs = ["dist/out.tar"]
run = "mkdir -p dist && tar -cf dist/out.tar build/out.txt"
