version = "0.3"

gen:
    @in data/input.txt
    @out build/out.txt
    @isolation off
    mkdir -p build
    tr '[:lower:]' '[:upper:]' < data/input.txt > build/out.txt

package: gen
    @in build/out.txt
    @out dist/out.tar
    @isolation off
    mkdir -p dist
    tar -cf dist/out.tar build/out.txt
