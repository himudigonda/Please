version = "0.4"

build_ui:
    @in frontend/package.json frontend/package-lock.json frontend/index.html frontend/src/**/* frontend/tsconfig.json frontend/vite.config.ts
    @out frontend/dist
    @dir frontend
    @isolation off
    npm ci
    npm run build

build_api:
    @in backend/Cargo.toml backend/src/**/*.rs
    @out backend/target/release/showcase-server
    @isolation off
    cargo build --release --manifest-path backend/Cargo.toml

package_container: build_ui build_api
    @in Dockerfile frontend/dist/**/* backend/target/release/showcase-server
    @out artifacts/showcase-image.tar
    @isolation off
    mkdir -p artifacts
    docker build -t please-showcase:latest .
    docker save please-showcase:latest -o artifacts/showcase-image.tar

run_container: package_container
    @in artifacts/showcase-image.tar
    @out .please/stamps/run_container.ok
    @isolation off
    mkdir -p .please/stamps
    docker load -i artifacts/showcase-image.tar
    docker rm -f please-showcase >/dev/null 2>&1 || true
    docker run -d --name please-showcase -p 8080:8080 please-showcase:latest
    printf 'ok\n' > .please/stamps/run_container.ok

prove_cache: build_ui build_api
    @in pleasefile scripts/prove-worth.sh
    @out artifacts/prove-cache.log
    @isolation off
    bash scripts/prove-worth.sh
