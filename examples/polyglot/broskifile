version = "0.5"

generate_data:
    @in data/input.txt
    @out build/generated.txt
    @isolation off
    mkdir -p build
    tr '[:lower:]' '[:upper:]' < data/input.txt > build/generated.txt

build_backend: generate_data
    @in src/**/*.rs Cargo.toml build/generated.txt
    @out target/release/backend
    @env RUST_LOG=info
    @isolation off
    cargo build --release

package: build_backend
    @in target/release/backend
    @out dist/backend.tar
    @isolation off
    mkdir -p dist
    tar -cf dist/backend.tar target/release/backend
