version = "0.4"

test:
    @in go.mod cmd/**/*.go
    @out .please/stamps/test.ok
    @isolation off
    mkdir -p .please/stamps
    go test ./...
    printf 'ok\n' > .please/stamps/test.ok

build: test
    @in go.mod cmd/**/*.go
    @out dist/go-http
    @isolation off
    mkdir -p dist
    go build -o dist/go-http ./cmd/server

ci: build
    @in pleasefile
    @out .please/stamps/ci.ok
    @isolation off
    mkdir -p .please/stamps
    printf 'ok\n' > .please/stamps/ci.ok
