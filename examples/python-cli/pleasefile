version = "0.3"

test:
    @in src/**/*.py tests/**/*.py
    @out .please/stamps/test.ok
    @isolation off
    mkdir -p .please/stamps
    python3 -m unittest discover -s tests -p 'test_*.py'
    printf 'ok\n' > .please/stamps/test.ok

package: test
    @in src/**/*.py
    @out dist/python-cli.tar
    @isolation off
    mkdir -p dist
    tar -cf dist/python-cli.tar src

ci: package
    @in pleasefile
    @out .please/stamps/ci.ok
    @isolation off
    mkdir -p .please/stamps
    printf 'ok\n' > .please/stamps/ci.ok
