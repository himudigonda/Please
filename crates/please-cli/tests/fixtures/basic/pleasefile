version = "0.3"
alias p = process

# Process input into dist output
process:
    @in src/input.txt
    @out dist/out.txt
    @isolation best_effort
    mkdir -p dist
    cat src/input.txt > dist/out.txt

fail_midway:
    @in src/input.txt
    @out dist/bad.txt
    @isolation best_effort
    mkdir -p dist
    echo 'poison' > dist/bad.txt
    exit 1

args_task:
    @in src/input.txt
    @out dist/args.txt
    @isolation best_effort
    mkdir -p dist
    echo > dist/args.txt

dev_echo:
    @mode interactive
    @isolation off
    echo interactive-ok
