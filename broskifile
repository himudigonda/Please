version = "0.5"

fmt:
    @in Cargo.toml Cargo.lock rustfmt.toml crates/**/*.rs
    @out .broski/stamps/fmt.ok
    @isolation off
    mkdir -p .broski/stamps
    cargo fmt --all --check
    printf 'ok\n' > .broski/stamps/fmt.ok

lint: fmt
    @in Cargo.toml Cargo.lock clippy.toml crates/**/*.rs
    @out .broski/stamps/lint.ok
    @isolation off
    mkdir -p .broski/stamps
    cargo clippy --workspace --all-targets --all-features -- -D warnings
    printf 'ok\n' > .broski/stamps/lint.ok

test: lint
    @in Cargo.toml Cargo.lock crates/**/*.rs crates/**/tests/**/*.rs
    @out .broski/stamps/test.ok
    @isolation off
    mkdir -p .broski/stamps
    if command -v cargo-nextest >/dev/null 2>&1; then
      cargo nextest run --workspace --all-features
    else
      cargo test --workspace --all-features
    fi
    printf 'ok\n' > .broski/stamps/test.ok

cov: test
    @in Cargo.toml Cargo.lock crates/**/*.rs
    @out .broski/stamps/cov.ok
    @isolation off
    mkdir -p .broski/stamps
    if ! command -v cargo-llvm-cov >/dev/null 2>&1; then
      cargo install --locked cargo-llvm-cov
    fi
    cargo llvm-cov --workspace --all-features --summary-only --fail-under-lines ${BROSKI_COVERAGE_MIN:-50}
    printf 'ok\n' > .broski/stamps/cov.ok

ci: cov
    @in broskifile
    @out .broski/stamps/ci.ok
    @isolation off
    mkdir -p .broski/stamps
    printf 'ok\n' > .broski/stamps/ci.ok

examples_smoke:
    @in broskifile examples/**/broskifile examples/**/src/**/* examples/**/Cargo.toml examples/**/go.mod examples/**/package.json
    @out .broski/stamps/examples_smoke.ok
    @isolation off
    mkdir -p .broski/stamps
    cargo run -p broski-cli -- --workspace examples/minimal run hello
    cargo run -p broski-cli -- --workspace examples/polyglot run package
    cargo run -p broski-cli -- --workspace examples/python-cli run ci
    cargo run -p broski-cli -- --workspace examples/go-http run ci
    cargo run -p broski-cli -- --workspace examples/node-web run ci
    printf 'ok\n' > .broski/stamps/examples_smoke.ok
